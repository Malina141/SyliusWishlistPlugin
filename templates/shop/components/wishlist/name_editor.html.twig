<div {{ attributes }}>
    {% if flashMessage %}
        <div class="alert alert-success" {{ sylius_test_html_attribute('wishlist-name-success-message') }}>{{ flashMessage|trans }}</div>
    {% endif %}

    <div class="d-inline-flex">
        {% if isEditing %}
            {{ form_start(form, {'attr': {'data-action': 'live#action:prevent', 'data-live-action-param': 'save'}}) }}
                <div class="row g-2 align-items-start">
                    <div class="col">
                        <div class="form-floating">
                            {{ form_widget(form.name, {
                                'attr': {
                                    'class': 'form-control form-control-lg' ~ (form.name.vars.errors|length > 0 ? ' is-invalid' : ''),
                                    'placeholder': ('malina141_sylius_wishlist.ui.name'|trans),
                                    'autofocus': true,
                                    'data-test-wishlist-name-input': ''
                                }
                            }) }}
                            {{ form_label(form.name) }}

                            {% if form.name.vars.errors|length > 0 %}
                                <div class="invalid-feedback d-block">
                                    {{ form_errors(form.name) }}
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <div class="col-auto">
                        <button
                            type="submit"
                            class="btn btn-outline-{{ form.name.vars.errors|length > 0 ? 'danger' : 'secondary' }} h-100"
                            {{ sylius_test_html_attribute('wishlist-name-save-button') }}
                        >
                            {{ 'malina141_sylius_wishlist.ui.save'|trans }}
                        </button>
                    </div>
                </div>
            {{ form_end(form) }}
        {% else %}
            <h2 {{ sylius_test_html_attribute('wishlist-name-display') }}>{{ wishlist.name ?: ('malina141_sylius_wishlist.ui.default_name'|trans) }}</h2>
            <button
                data-action="live#action"
                data-live-action-param="activateEditing"
                class="btn btn-link"
                title="{{ 'malina141_sylius_wishlist.ui.edit_name'|trans }}"
                {{ sylius_test_html_attribute('wishlist-name-edit-button') }}
            >
                {{ ux_icon('tabler:edit', { class: 'icon icon-sm' }) }}
            </button>
        {% endif %}
    </div>
</div>
