<?xml version="1.0" encoding="UTF-8"?>

<container
    xmlns="http://symfony.com/schema/dic/services"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd"
>
    <services>
        <defaults public="true" />

        <service
            id="malina141_sylius_wishlist.behat.context.setup.wishlist"
            class="Tests\Malina141\SyliusWishlistPlugin\Behat\Context\Setup\WishlistContext"
        >
            <argument type="service" id="sylius.behat.shared_storage" />
            <argument type="service" id="malina141_sylius_wishlist.factory.wishlist" />
            <argument type="service" id="malina141_sylius_wishlist.modifier.wishlist" />
            <argument type="service" id="sylius.resolver.product_variant.default" />
            <argument type="service" id="malina141_sylius_wishlist.manager.wishlist" />
            <argument type="service" id="sylius.behat.cookie_setter" />
            <argument type="service" id="malina141_sylius_wishlist.provider.wishlist_share_token" />
            <argument type="service" id="sylius.repository.customer" />
            <argument>%malina141_sylius_wishlist.cookie.name%</argument>
        </service>

        <service
            id="malina141_sylius_wishlist.behat.context.ui.shop.wishlist"
            class="Tests\Malina141\SyliusWishlistPlugin\Behat\Context\Ui\Shop\WishlistContext"
        >
            <argument type="service" id="malina141_sylius_wishlist.behat.page.shop.wishlist.index" />
            <argument type="service" id="malina141_sylius_wishlist.behat.page.shop.wishlist.shared_show" />
            <argument type="service" id="malina141_sylius_wishlist.behat.element.shop.wishlist_widget" />
            <argument type="service" id="malina141_sylius_wishlist.behat.element.shop.product_wishlist" />
            <argument type="service" id="sylius.behat.shared_storage" />
            <argument type="service" id="sylius.behat.page.shop.home" />
            <argument type="service" id="sylius.behat.page.shop.cart_summary" />
            <argument type="service" id="sylius.behat.notification_checker.shop" />
        </service>

        <service
            id="malina141_sylius_wishlist.behat.context.ui.admin.wishlist"
            class="Tests\Malina141\SyliusWishlistPlugin\Behat\Context\Ui\Admin\WishlistContext"
        >
            <argument type="service" id="malina141_sylius_wishlist.behat.page.admin.wishlist.index" />
            <argument type="service" id="malina141_sylius_wishlist.behat.page.admin.wishlist.show" />
            <argument type="service" id="sylius.resolver.product_variant.default" />
        </service>

        <service
            id="malina141_sylius_wishlist.behat.element.shop.wishlist_widget"
            class="Tests\Malina141\SyliusWishlistPlugin\Behat\Element\Shop\WishlistWidgetElement"
            parent="sylius.behat.element"
            public="false"
        />

        <service
            id="malina141_sylius_wishlist.behat.element.shop.product_wishlist"
            class="Tests\Malina141\SyliusWishlistPlugin\Behat\Element\Shop\ProductWishlistElement"
            parent="sylius.behat.element"
            public="false"
        />

        <service
            id="malina141_sylius_wishlist.behat.page.shop.wishlist.index"
            class="Tests\Malina141\SyliusWishlistPlugin\Behat\Page\Shop\Wishlist\IndexPage"
            parent="sylius.behat.symfony_page"
            public="false"
        >
            <argument type="service" id="sylius.behat.table_accessor" />
        </service>

        <service
            id="malina141_sylius_wishlist.behat.page.shop.wishlist.shared_show"
            class="Tests\Malina141\SyliusWishlistPlugin\Behat\Page\Shop\Wishlist\SharedShowPage"
            parent="sylius.behat.symfony_page"
            public="false"
        />

        <service
            id="malina141_sylius_wishlist.behat.page.admin.wishlist.index"
            class="Tests\Malina141\SyliusWishlistPlugin\Behat\Page\Admin\Wishlist\IndexPage"
            parent="sylius.behat.symfony_page"
            public="false"
        >
            <argument type="service" id="sylius.behat.table_accessor" />
        </service>

        <service
            id="malina141_sylius_wishlist.behat.page.admin.wishlist.show"
            class="Tests\Malina141\SyliusWishlistPlugin\Behat\Page\Admin\Wishlist\ShowPage"
            parent="sylius.behat.symfony_page"
            public="false"
        />
    </services>
</container>
