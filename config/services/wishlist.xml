<?xml version="1.0" encoding="UTF-8" ?>

<container
    xmlns="http://symfony.com/schema/dic/services"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd"
>
    <services>
        <service id="malina141_sylius_wishlist.options.wishlist_cookie"
                 class="Malina141\SyliusWishlistPlugin\Options\WishlistCookieOptions">
            <argument>%malina141_sylius_wishlist.cookie.name%</argument>
            <argument>%malina141_sylius_wishlist.cookie.lifetime%</argument>
            <argument>%malina141_sylius_wishlist.cookie.path%</argument>
            <argument>%malina141_sylius_wishlist.cookie.secure%</argument>
            <argument>%malina141_sylius_wishlist.cookie.http_only%</argument>
            <argument>%malina141_sylius_wishlist.cookie.same_site%</argument>
        </service>

        <service id="malina141_sylius_wishlist.factory.wishlist_cookie"
                 class="Malina141\SyliusWishlistPlugin\Factory\WishlistCookieFactory">
            <argument type="service" id="malina141_sylius_wishlist.options.wishlist_cookie"/>
            <argument type="service" id="clock"/>
        </service>

        <service id="malina141_sylius_wishlist.provider.wishlist_token"
                 class="Malina141\SyliusWishlistPlugin\Provider\WishlistCookieTokenProvider">
            <argument type="service" id="request_stack"/>
            <argument>%malina141_sylius_wishlist.cookie.name%</argument>
            <argument type="service" id="Sylius\Resource\Generator\RandomnessGeneratorInterface"/>
            <argument>%malina141_sylius_wishlist.token.length%</argument>
        </service>

        <service id="malina141_sylius_wishlist.context.wishlist.customer_based"
                 class="Malina141\SyliusWishlistPlugin\Context\CustomerBasedWishlistContext">
            <argument type="service" id="sylius.context.customer"/>
            <argument type="service" id="malina141_sylius_wishlist.repository.wishlist"/>
            <argument type="service" id="sylius.context.channel"/>

            <tag name="malina141_sylius_wishlist.wishlist_context" priority="10"/>
        </service>

        <service id="malina141_sylius_wishlist.context.wishlist.token_and_channel_based"
                 class="Malina141\SyliusWishlistPlugin\Context\TokenAndChannelBasedWishlistContext">
            <argument type="service" id="malina141_sylius_wishlist.provider.wishlist_token"/>
            <argument type="service" id="sylius.context.channel"/>
            <argument type="service" id="malina141_sylius_wishlist.repository.wishlist"/>

            <tag name="malina141_sylius_wishlist.wishlist_context" priority="0"/>
        </service>

        <service id="malina141_sylius_wishlist.context.wishlist.new"
                 class="Malina141\SyliusWishlistPlugin\Context\NewWishlistContext">
            <argument type="service" id="malina141_sylius_wishlist.factory.wishlist"/>
            <argument type="service" id="sylius.context.customer"/>
            <argument type="service" id="sylius.context.channel"/>
            <argument type="service" id="malina141_sylius_wishlist.provider.wishlist_token"/>

            <tag name="malina141_sylius_wishlist.wishlist_context" priority="-10"/>
        </service>

        <service id="malina141_sylius_wishlist.context.wishlist"
                 class="Malina141\SyliusWishlistPlugin\Context\CompositeWishlistContext"
                 public="true">
            <argument type="tagged_iterator" tag="malina141_sylius_wishlist.wishlist_context"/>
        </service>

        <service id="malina141_sylius_wishlist.merger.wishlist"
                 class="Malina141\SyliusWishlistPlugin\Merger\WishlistMerger">
            <argument type="service" id="malina141_sylius_wishlist.repository.wishlist"/>
            <argument type="service" id="malina141_sylius_wishlist.manager.wishlist"/>
        </service>

        <service id="malina141_sylius_wishlist.merger.guest_wishlist_login"
                 class="Malina141\SyliusWishlistPlugin\Merger\GuestWishlistLoginMerger">
            <argument type="service" id="sylius.context.channel"/>
            <argument type="service" id="malina141_sylius_wishlist.repository.wishlist"/>
            <argument type="service" id="malina141_sylius_wishlist.merger.wishlist"/>
            <argument type="service" id="malina141_sylius_wishlist.manager.wishlist"/>
        </service>

        <service id="malina141_sylius_wishlist.event_subscriber.attach_wishlist_cookie_token"
                 class="Malina141\SyliusWishlistPlugin\EventSubscriber\AttachWishlistCookieTokenSubscriber">
            <argument type="service" id="malina141_sylius_wishlist.factory.wishlist_cookie"/>
            <argument>%malina141_sylius_wishlist.cookie.name%</argument>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="malina141_sylius_wishlist.event_subscriber.merge_wishlist_on_login"
                 class="Malina141\SyliusWishlistPlugin\EventSubscriber\MergeWishlistOnLoginSubscriber">
            <argument type="service" id="malina141_sylius_wishlist.options.wishlist_cookie"/>
            <argument type="service" id="malina141_sylius_wishlist.merger.guest_wishlist_login"/>
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="malina141_sylius_wishlist.custom_factory.wishlist_item"
                 class="Malina141\SyliusWishlistPlugin\Factory\WishlistItemFactory"
                 decorates="malina141_sylius_wishlist.factory.wishlist_item" public="false">
            <argument type="service" id="malina141_sylius_wishlist.custom_factory.wishlist_item.inner"/>
        </service>

        <service id="malina141_sylius_wishlist.modifier.wishlist"
                 class="Malina141\SyliusWishlistPlugin\Modifier\WishlistModifier">
            <argument type="service" id="malina141_sylius_wishlist.factory.wishlist_item"/>
        </service>

        <service id="malina141_sylius_wishlist.twig.component.wishlist.add_to_wishlist"
                 class="Malina141\SyliusWishlistPlugin\Twig\Component\Wishlist\AddToWishlistComponent"
        >
            <argument type="service" id="malina141_sylius_wishlist.context.wishlist"/>
            <argument type="service" id="malina141_sylius_wishlist.modifier.wishlist"/>
            <argument type="service" id="malina141_sylius_wishlist.manager.wishlist"/>
            <argument type="service" id="sylius.repository.product"/>
            <argument type="service" id="sylius.repository.product_variant"/>

            <call method="setLiveResponder">
                <argument type="service" id="ux.live_component.live_responder"/>
            </call>

            <tag name="sylius.live_component.shop" key="sylius_shop:wishlist:add_to_wishlist"/>
        </service>

        <service id="malina141_sylius_wishlist.twig.component.wishlist.widget"
                 class="Malina141\SyliusWishlistPlugin\Twig\Component\Wishlist\WishlistWidgetComponent"
        >
            <argument type="service" id="malina141_sylius_wishlist.context.wishlist"/>

            <tag name="sylius.live_component.shop" key="sylius_shop:wishlist:widget"/>
        </service>

        <service id="malina141_sylius_wishlist.form.type.wishlist_name"
                 class="Malina141\SyliusWishlistPlugin\Form\Type\WishlistNameType">
            <tag name="form.type"/>
        </service>

        <service id="malina141_sylius_wishlist.twig.component.wishlist.name_editor"
                 class="Malina141\SyliusWishlistPlugin\Twig\Component\Wishlist\WishlistNameEditor"
        >
            <argument type="service" id="malina141_sylius_wishlist.context.wishlist"/>
            <argument type="service" id="malina141_sylius_wishlist.manager.wishlist"/>
            <argument type="service" id="form.factory"/>

            <tag name="sylius.live_component.shop" key="sylius_shop:wishlist:name_editor"/>
        </service>

        <service id="malina141_sylius_wishlist.adder.wishlist_items_to_cart"
                 class="Malina141\SyliusWishlistPlugin\Adder\WishlistItemsToCartAdder">
            <argument type="service" id="sylius.factory.order_item"/>
            <argument type="service" id="sylius.modifier.order_item_quantity"/>
            <argument type="service" id="sylius.modifier.order"/>
            <argument type="service" id="sylius.manager.order"/>
            <argument type="service" id="sylius.factory.add_to_cart_command"/>
            <argument type="service" id="malina141_sylius_wishlist.validator.add_to_cart_command"/>
        </service>

        <service id="malina141_sylius_wishlist.controller.action.add_wishlist_items_to_cart"
                 class="Malina141\SyliusWishlistPlugin\Controller\Action\AddWishlistItemsToCartAction"
                 public="true">
            <argument type="service" id="malina141_sylius_wishlist.adder.wishlist_items_to_cart"/>
            <argument type="service" id="malina141_sylius_wishlist.context.wishlist"/>
            <argument type="service" id="sylius.context.cart"/>
            <argument type="service" id="malina141_sylius_wishlist.repository.wishlist_item"/>
            <argument type="service" id="security.csrf.token_manager"/>
            <argument type="service" id="router"/>
            <argument>%malina141_sylius_wishlist.bulk_add_to_cart.redirect_route%</argument>
            <argument>%malina141_sylius_wishlist.bulk_add_to_cart.csrf_token_id%</argument>
        </service>

        <service id="malina141_sylius_wishlist.validator.add_to_cart_command"
                 class="Malina141\SyliusWishlistPlugin\Validator\AddToCartCommandValidator">
            <argument type="service" id="validator"/>
            <argument type="collection">
                <argument>sylius</argument>
            </argument>
        </service>

        <service id="malina141_sylius_wishlist.provider.wishlist_share_token"
                 class="Malina141\SyliusWishlistPlugin\Provider\WishlistShareTokenProvider">
            <argument type="service" id="Sylius\Resource\Generator\RandomnessGeneratorInterface"/>
            <argument>%malina141_sylius_wishlist.share_token.length%</argument>
        </service>

        <service id="malina141_sylius_wishlist.event_listener.workflow.provide_wishlist_share_token"
                 class="Malina141\SyliusWishlistPlugin\EventListener\Workflow\ProvideWishlistShareTokenListener">
            <argument type="service" id="malina141_sylius_wishlist.provider.wishlist_share_token"/>
            <tag name="kernel.event_listener" event="workflow.sylius_wishlist.completed.share"/>
        </service>

        <service id="malina141_sylius_wishlist.event_listener.workflow.clear_wishlist_share_token"
                 class="Malina141\SyliusWishlistPlugin\EventListener\Workflow\ClearWishlistShareTokenListener">
            <tag name="kernel.event_listener" event="workflow.sylius_wishlist.completed.unshare"/>
        </service>

        <service id="malina141_sylius_wishlist.event_subscriber.admin_menu_builder"
                 class="Malina141\SyliusWishlistPlugin\EventSubscriber\AdminMenuBuilder">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="malina141_sylius_wishlist.grid_filter.exists" 
                class="Malina141\SyliusWishlistPlugin\Grid\Filter\ExistsFilter">
            <tag name="sylius.grid_filter" type="malina141_exists" form_type="Sylius\Bundle\GridBundle\Form\Type\Filter\SelectFilterType" />
        </service>

    </services>
</container>
