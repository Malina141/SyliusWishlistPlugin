                class="ApiPlatform\Metadata\Post"
                uriTemplate="/shop/wishlists"
                itemUriTemplate="/shop/wishlists/{token}"
                messenger="input"
                input="Malina141\SyliusWishlistPlugin\Api\Command\Shop\Wishlist\CreateWishlist"
            >
                <denormalizationContext>
                    <values>
                        <value name="groups">
                            <values>
                                <value>malina141:shop:wishlist:create</value>
                            </values>
                        </value>
                    </values>
                </denormalizationContext>
                <normalizationContext>
                    <values>
                        <value name="groups">
                            <values>
                                <value>malina141:shop:wishlist:show</value>
