                class="ApiPlatform\Metadata\Get"
                uriTemplate="/shop/wishlists/{token}"
                provider="malina141_sylius_wishlist.api.state_provider.shop.wishlist.item"
            >
                <normalizationContext>
                    <values>
                        <value name="groups">
                            <values>
                                <value>malina141:shop:wishlist:show</value>
                            </values>
                        </value>
                    </values>
                </normalizationContext>
            </operation>

            <operation
